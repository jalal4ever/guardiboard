# =============================================================================
# GUARDIBOARD - Variables d'environnement
# =============================================================================
# Copier ce fichier en .env et remplir les valeurs
# WARNING: Ne jamais commit ce fichier avec des valeurs réelles !

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Base de données (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/guardiboard
DATABASE_POOL_SIZE=10
DATABASE_IDLE_TIMEOUT=30000
DATABASE_CONNECT_TIMEOUT=5000

# -----------------------------------------------------------------------------
# Authentification (OIDC/Session)
# -----------------------------------------------------------------------------
SESSION_SECRET=your-session-secret-min-32-chars
SESSION_MAX_AGE=86400000

# OAuth Provider (ex: Auth0, Azure AD, etc.)
OAUTH_ISSUER=https://your-tenant.auth0.com
OAUTH_CLIENT_ID=your-oauth-client-id
OAUTH_CLIENT_SECRET=your-oauth-client-secret
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# -----------------------------------------------------------------------------
# Microsoft Graph (M365)
# -----------------------------------------------------------------------------
# Azure AD - Application multi-tenant
AZURE_TENANT_ID=
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=  # Utiliser certificat en production
AZURE_CLIENT_CERT_PATH=
AZURE_CLIENT_CERT_PASSWORD=

# Microsoft Graph API
GRAPH_API_SCOPE=https://graph.microsoft.com/.default
GRAPH_API_BASE_URL=https://graph.microsoft.com/v1.0

# -----------------------------------------------------------------------------
# Azure Key Vault (Secrets)
# -----------------------------------------------------------------------------
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/
AZURE_KEY_VAULT_TENANT_ID=
AZURE_KEY_VAULT_CLIENT_ID=
AZURE_KEY_VAULT_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Collecteur AD On-Premise
# -----------------------------------------------------------------------------
COLLECTOR_ENROLLMENT_TOKEN_SECRET=your-enrollment-secret
COLLECTOR_API_URL=https://api.guardiboard.internal
COLLECTOR_TLS_PIN=

# -----------------------------------------------------------------------------
# Workers / Jobs
# -----------------------------------------------------------------------------
QUEUE_CONCURRENCY=5
COLLECTION_INTERVAL_MS=3600000
GRACE_PERIOD_MS=300000

# -----------------------------------------------------------------------------
# Logging & Observabilité
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_PRETTY=false

# -----------------------------------------------------------------------------
# Features Flags
# -----------------------------------------------------------------------------
FEATURE_AD_COLLECTION_ENABLED=true
FEATURE_M365_COLLECTION_ENABLED=true
FEATURE_HYBRID_CORRELATION=false
